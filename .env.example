# =============================================================================
# Upstash Vector
# Create index at: https://console.upstash.com/vector
# Choose built-in model: BAAI/bge-large-en-v1.5 (1024 dimensions)
# =============================================================================
UPSTASH_VECTOR_URL=
UPSTASH_VECTOR_TOKEN=

# =============================================================================
# Upstash QStash
# Get keys at: https://console.upstash.com/qstash
# =============================================================================
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Public URL of this API (QStash will POST to this for async ingestion)
# For local dev with ngrok: https://xxxx.ngrok-free.app
APP_PUBLIC_URL=http://localhost:8000

# =============================================================================
# LLM Providers
# =============================================================================
GROQ_API_KEY=
OPENAI_API_KEY=           # Optional — used for A/B eval comparison

# Default model for queries
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq         # "groq" or "openai"

# =============================================================================
# Langfuse Observability
# Sign up free at: https://cloud.langfuse.com
# =============================================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# GitHub
# =============================================================================
GITHUB_TOKEN=             # Optional — raises rate limits to 5000 req/hr

# =============================================================================
# App Settings
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO

# Max files to process per repository (free tier safety limit)
MAX_FILES_PER_REPO=500

# Max file size in bytes (skip larger files)
MAX_FILE_SIZE_BYTES=102400

# Vector search top-K
DEFAULT_TOP_K=8

# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./data/codebase_assistant.db
